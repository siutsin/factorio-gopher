# EditorConfig: https://EditorConfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
max_line_length = 180
tab_width = 2
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

[*.md]
max_line_length = off  # handled by markdownlint
indent_size = unset    # markdown indentation handled by markdownlint
indent_style = unset
